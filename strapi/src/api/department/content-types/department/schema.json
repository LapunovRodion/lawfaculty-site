{
  "kind": "collectionType",
  "collectionName": "departments",
  "info": {
    "singularName": "department",
    "pluralName": "departments",
    "displayName": "Department",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "tagline": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "overview": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "history": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "teachingSummary": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "researchSummary": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "headNote": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "contacts": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "office": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "keyFacts": {
      "type": "component",
      "repeatable": true,
      "component": "department.fact",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "disciplines": {
      "type": "component",
      "repeatable": true,
      "component": "department.discipline",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "usefulLinks": {
      "type": "component",
      "repeatable": true,
      "component": "department.link-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "documents": {
      "type": "component",
      "repeatable": true,
      "component": "department.document-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "extraSections": {
      "type": "dynamiczone",
      "components": ["department.rich-section"],
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "persons": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::person.person",
      "mappedBy": "departments"
    }
  }
}
